{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema/markdownlint-config-schema.json",
  "line-length": false,
  "no-inline-html": {
    "allowed_elements": [
      "details",
      "summary"
    ],
    "table_allowed_elements": [
      "br"
    ]
  },
  "no-duplicate-heading": {
    "siblings_only": true
  }
}
