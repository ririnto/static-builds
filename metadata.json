{
  "nginx": {
    "tag_prefix": "nginx",
    "release_files": [
      "sbin/nginx"
    ],
    "env": {
      "ALPINE_VERSION": "3.23.4",
      "NGINX_VERSION": "1.30.2",
      "NGINX_VTS_MODULE_VERSION": "0.2.5",
      "UBI10_MINIMAL_VERSION": "10.1-1778576723"
    },
    "downloads": [
      {
        "url": "https://nginx.org/download/nginx-{NGINX_VERSION}.tar.gz",
        "name": "nginx-{NGINX_VERSION}.tar.gz"
      },
      {
        "url": "https://github.com/vozlt/nginx-module-vts/archive/refs/tags/v{NGINX_VTS_MODULE_VERSION}.tar.gz",
        "name": "nginx-module-vts-{NGINX_VTS_MODULE_VERSION}.tar.gz"
      }
    ],
    "version_env_var": "NGINX_VERSION"
  },
